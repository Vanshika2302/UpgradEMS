@model List<UpGradEMS.DAL.Models.EventDetails>

<div class="text-center text-white p-5" style="background-color:#dc3545;">

    <h1 class="fw-bold">UpGrad Virtual Event Management System</h1>

    <p class="mt-3">
        Explore events, connect with experts, and grow your skills.
    </p>

    <a asp-controller="Event" asp-action="Index" class="btn btn-dark mt-3 px-4">
        Explore Events
    </a>

</div>

<div class="container mt-5">

    <h2 class="text-center text-danger mb-4">Upcoming Events</h2>

    <div class="row">

        @if (Model != null && Model.Count > 0)
        {
            foreach (var e in Model)
            {
                <div class="col-md-4">

                    <div class="card shadow mb-4">

                        <div class="card-body">

                            <h5 class="card-title">@e.EventName</h5>

                            <p><b>Category:</b> @e.EventCategory</p>

                            <p><b>Date:</b> @e.EventDate.ToShortDateString()</p>

                            <p><b>Status:</b> @e.Status</p>

                            <a asp-controller="Participant"
                               asp-action="RegisterEvent"
                               asp-route-eventId="@e.EventId"
                               class="btn btn-success w-100">
                                Join Event
                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <p class="text-center">No events available</p>
        }

    </div>

</div>